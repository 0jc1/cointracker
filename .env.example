# Copy to `.env` and fill in values (`cp .env.example .env`).
# `.env` is gitignored.

# Django — used in cointracker/settings.py
# Generate a new key for anything non-local, e.g.:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-string

# Leave unset or empty for local dev (SQLite, DEBUG on).
# On Heroku: `heroku config:set IS_HEROKU=True`
# IS_HEROKU=

# Optional — only needed when IS_HEROKU is truthy (Postgres on Heroku sets this automatically).
# DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME

# Chainlink price feeds — Web3 HTTP RPC URL (Ethereum mainnet), used in services/crypto_price.py
# Examples: Infura, Alchemy, your own node.
CHAINLINK_ENDPOINT=https://mainnet.infura.io/v3/YOUR_INFURA_PROJECT_ID
